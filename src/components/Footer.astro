---
// Footer.astro — Site footer
---

<footer class="site-footer">
  <div class="footer-logo">Byzantine Doors</div>
  <div class="footer-text">
    Catechetical and parish resources for the Byzantine Christian tradition
  </div>
  <div class="footer-links">
    <a href="#">About</a>
    <a href="#">Contact</a>
    <a href="#">Sources</a>
    <a href="#">Privacy</a>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 0.5px solid var(--gold-10);
    padding: 48px 0 40px;
    text-align: center;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 300;
    color: var(--halo-gold);
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .footer-text {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--deep-muted);
    line-height: 1.8;
  }
  .footer-links {
    margin-top: 16px;
    display: flex;
    gap: 24px;
    justify-content: center;
  }
  .footer-links a {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--censer-smoke);
    letter-spacing: 0.5px;
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--beeswax);
  }
</style>
