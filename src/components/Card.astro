---
// Card.astro — Standard card component
interface Props {
  title: string;
  description?: string;
  number?: string;
  href?: string;
}

const { title, description, number, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="card" href={href || undefined}>
  {number && <div class="card-number">{number}</div>}
  <div class="card-title">{title}</div>
  {description && <div class="card-desc">{description}</div>}
  <slot />
</Tag>

<style>
  .card {
    display: block;
    background: var(--icon-wall);
    border: 0.5px solid var(--gold-10);
    border-radius: 12px;
    padding: 28px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.2s;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-40), transparent);
  }
  .card:hover {
    border-color: var(--gold-15);
    transform: translateY(-2px);
  }
  .card-number {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 300;
    color: var(--halo-gold);
    opacity: 0.3;
    position: absolute;
    top: 16px;
    right: 20px;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    color: var(--beeswax);
    margin-bottom: 8px;
  }
  .card-desc {
    font-size: 15px;
    color: var(--censer-smoke);
    line-height: 1.6;
  }
</style>
