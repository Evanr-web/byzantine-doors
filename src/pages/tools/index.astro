---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Tools & Guides" description="Practical guides for Eastern Christian life — your first visit, fasting, prayer corners, and feast-day hymns.">

  <section class="hero" style="padding-bottom:40px;">
    <div class="hero-content">
      <div class="section-label" style="margin-bottom:16px;">Tools & Guides</div>
      <h1 class="hero-title" style="font-size:34px;">Practical Guides</h1>
      <p class="hero-subtitle">
        Everything you need to know before, during, and after your encounters with Eastern Christianity. No prior knowledge required.
      </p>
    </div>
  </section>

  <div class="container" style="padding-bottom:80px;">
    <div class="tools-grid">

      <a href="/tools/first-visit/" class="tool-card">
        <div class="tool-card-icon">🚪</div>
        <div class="tool-card-body">
          <h3>Your First Visit to a Byzantine Parish</h3>
          <p>Everything you need to know before, during, and after your first Divine Liturgy. You'll be fine — here's how.</p>
          <span class="tool-card-tag">Start Here</span>
        </div>
      </a>

      <a href="/tools/fasting-guide/" class="tool-card">
        <div class="tool-card-icon">🍞</div>
        <div class="tool-card-body">
          <h3>Byzantine Fasting Guide</h3>
          <p>The rhythm of fasting and feasting in the Eastern tradition — what to eat, when, and why it matters for the soul.</p>
          <span class="tool-card-tag">Practice</span>
        </div>
      </a>

      <a href="/tools/prayer-corner/" class="tool-card">
        <div class="tool-card-icon">🕯️</div>
        <div class="tool-card-body">
          <h3>Setting Up a Home Prayer Corner</h3>
          <p>How to create a sacred space in your home — icons, candles, and the art of praying where you live.</p>
          <span class="tool-card-tag">Practice</span>
        </div>
      </a>

      <a href="/tools/troparion-cards/" class="tool-card">
        <div class="tool-card-icon">🎵</div>
        <div class="tool-card-body">
          <h3>Troparion Cards for Major Feasts</h3>
          <p>Printable cards with the troparion (main hymn) for each major feast of the liturgical year — text and melody guides.</p>
          <span class="tool-card-tag">Reference</span>
        </div>
      </a>

    </div>
  </div>

</BaseLayout>

<style>
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .tool-card {
    display: flex;
    gap: 20px;
    background: var(--icon-wall);
    border: 0.5px solid var(--gold-10);
    border-radius: 12px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }
  .tool-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-40), transparent);
  }
  .tool-card:hover {
    border-color: var(--gold-15);
    transform: translateY(-2px);
    opacity: 1;
  }
  .tool-card-icon {
    font-size: 28px;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0.5px solid var(--gold-10);
    border-radius: 10px;
    background: var(--gold-04);
  }
  .tool-card-body h3 {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 400;
    color: var(--beeswax);
    margin-bottom: 8px;
  }
  .tool-card-body p {
    font-size: 14px;
    color: var(--censer-smoke);
    line-height: 1.6;
    margin-bottom: 12px;
  }
  .tool-card-tag {
    font-family: var(--font-ui);
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--halo-gold);
    padding: 4px 10px;
    border: 0.5px solid var(--gold-15);
    border-radius: 12px;
  }
  @media (max-width: 768px) {
    .tools-grid { grid-template-columns: 1fr; }
    .tool-card { flex-direction: column; gap: 12px; }
  }
</style>
