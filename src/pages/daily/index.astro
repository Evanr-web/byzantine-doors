---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Daily" description="Today's liturgical day — saints, troparion, fasting, and tone from the UGCC liturgical calendar.">

  <!-- Schema.org for daily liturgical content -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Daily Liturgical Calendar — Byzantine Doors",
    "description": "Today's saint, troparion, kontakion, scripture readings, fasting rules, and liturgical tone from the Ukrainian Greek-Catholic Church calendar.",
    "isPartOf": { "@type": "WebSite", "name": "Byzantine Doors", "url": "https://byzantinedoors.com" },
    "about": {
      "@type": "Event",
      "name": "Daily Liturgical Commemoration",
      "description": "UGCC liturgical calendar with daily saints, troparia, kontakia, and scripture readings for 2026.",
      "organizer": { "@type": "Organization", "name": "Ukrainian Greek-Catholic Church" }
    }
  })} />

  <!-- Daily Hero (populated by JS) -->
  <div class="daily-page-hero">
    <div class="container--narrow">
      <div class="daily-page-date" id="daily-date">Loading…</div>
      <h1 class="daily-page-feast" id="daily-saints">—</h1>
      <div class="daily-page-tone" id="daily-meta">—</div>
    </div>
  </div>

  <div class="container--narrow" style="padding-bottom:80px;">

    <!-- Date Navigation -->
    <div class="date-nav">
      <button class="date-nav-btn" id="prev-day" aria-label="Previous day">‹</button>
      <button class="date-nav-today" id="today-btn">Today</button>
      <button class="date-nav-btn" id="next-day" aria-label="Next day">›</button>
    </div>

    <!-- Troparion -->
    <div class="daily-section" id="section-troparion" style="display:none;">
      <div class="daily-section-label">Troparion</div>
      <p class="daily-prayer-text" id="daily-troparion"></p>
    </div>

    <!-- Kontakion -->
    <div class="daily-section" id="section-kontakion" style="display:none;">
      <div class="daily-section-label">Kontakion</div>
      <p class="daily-prayer-text" id="daily-kontakion"></p>
    </div>

    <!-- Fasting & Season Info -->
    <div class="daily-section" id="section-fast">
      <div class="daily-section-label">Liturgical Day</div>
      <div class="info-grid">
        <div class="info-item">
          <div class="info-label">Tone</div>
          <div class="info-value" id="info-tone">—</div>
        </div>
        <div class="info-item">
          <div class="info-label">Fast</div>
          <div class="info-value" id="info-fast">—</div>
        </div>
        <div class="info-item">
          <div class="info-label">Rank</div>
          <div class="info-value" id="info-rank">—</div>
        </div>
        <div class="info-item">
          <div class="info-label">Season</div>
          <div class="info-value" id="info-season">—</div>
        </div>
      </div>
    </div>

    <!-- Saints (Ukrainian) — hidden on English site, data retained in API -->
    <div class="daily-section" id="section-saints-uk" style="display:none !important;"></div>

    <!-- Scripture Readings -->
    <div class="daily-section" id="section-readings" style="display:none;">
      <div class="daily-section-label">Scripture Readings</div>
      <div id="daily-readings"></div>
      <div class="readings-attribution" id="readings-attribution" style="display:none;">
        World English Bible (public domain)
      </div>
    </div>

    <!-- Available Services — hidden until PWA is presentation-ready -->

    <!-- From the Fathers -->
    <div class="daily-section" id="section-fathers" style="display:none;">
      <div class="daily-section-label">☦ From the Fathers</div>
      <div class="fathers-reading-ref" id="fathers-reading-ref"></div>
      <div class="fathers-carousel">
        <div class="fathers-cards" id="fathers-cards"></div>
        <div class="fathers-nav">
          <button class="fathers-nav-btn" id="fathers-prev" aria-label="Previous reflection">‹</button>
          <div class="fathers-dots" id="fathers-dots"></div>
          <button class="fathers-nav-btn" id="fathers-next" aria-label="Next reflection">›</button>
        </div>
      </div>
      <div class="fathers-attribution">
        Patristic texts from <em>Nicene and Post-Nicene Fathers</em> (1889) and <em>Catena Aurea</em>, tr. Newman (1841). Public domain.
      </div>
    </div>

    <!-- Rubrics -->
    <div class="daily-section" id="section-rubrics" style="display:none;">
      <div class="daily-section-label">Устав</div>
      <p class="rubrics-text" id="daily-rubrics"></p>
    </div>

    <!-- Loading / Error states -->
    <div class="daily-section" id="section-loading">
      <p style="text-align:center; color:var(--censer-smoke);">Loading liturgical data…</p>
    </div>

    <div class="daily-section" id="section-error" style="display:none;">
      <p style="text-align:center; color:var(--censer-smoke);">Unable to load data for this date. The calendar API covers January–December 2026.</p>
    </div>

    <!-- About -->
    <div class="about-box">
      <p>Liturgical calendar data follows the Byzantine (Gregorian/New Calendar) tradition as used by Ukrainian Greek-Catholic parishes. English troparia and kontakia courtesy of the <a href="https://www.oca.org/saints">Orthodox Church in America</a>. Service texts courtesy of <a href="https://liturgy.royaldoors.net">Royal Doors</a>. Patristic reflections from <em>Nicene and Post-Nicene Fathers</em> (1889) and <em>Catena Aurea</em>, tr. Newman (1841) — public domain. This is an independent project and is not an official publication of any church body.</p>
    </div>

  </div>

</BaseLayout>

<script is:inline>
  const API_BASE = 'https://evanr-web.github.io/calendar-api/api/2026';
  
  const MONTHS_EN = ['','January','February','March','April','May','June',
                     'July','August','September','October','November','December'];
  const DAYS_OF_WEEK = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  // API uses 1=Mon..7=Sun, JS Date uses 0=Sun..6=Sat
  const DOW_FROM_API = {1:'Monday',2:'Tuesday',3:'Wednesday',4:'Thursday',5:'Friday',6:'Saturday',7:'Sunday'};
  
  let currentDate = new Date();
  
  function formatDateDisplay(d) {
    return `${DAYS_OF_WEEK[d.getDay()]}, ${MONTHS_EN[d.getMonth()+1]} ${d.getDate()}, ${d.getFullYear()}`;
  }
  
  function mm(d) { return String(d.getMonth()+1).padStart(2,'0'); }
  function dd(d) { return String(d.getDate()).padStart(2,'0'); }
  
  async function loadDay(date) {
    const m = mm(date);
    const d = dd(date);
    
    document.getElementById('daily-date').textContent = formatDateDisplay(date);
    document.getElementById('daily-saints').textContent = 'Loading…';
    document.getElementById('daily-meta').textContent = '';
    
    // Hide all content sections, show loading
    ['section-troparion','section-kontakion','section-saints-uk','section-readings','section-rubrics'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });
    document.getElementById('section-loading').style.display = '';
    document.getElementById('section-error').style.display = 'none';
    
    try {
      const resp = await fetch(`${API_BASE}/${m}/${d}.json`);
      if (!resp.ok) throw new Error('Not found');
      const data = await resp.json();
      renderDay(data, date);
    } catch (e) {
      document.getElementById('section-loading').style.display = 'none';
      document.getElementById('section-error').style.display = '';
      document.getElementById('daily-saints').textContent = 'Data unavailable';
      document.getElementById('daily-meta').textContent = '';
    }
  }
  
  function renderDay(data, date) {
    try {
    document.getElementById('section-loading').style.display = 'none';
    
    // Hero
    document.getElementById('daily-date').textContent = formatDateDisplay(date);
    
    const saintEN = data.saints?.en || '';
    document.getElementById('daily-saints').textContent = saintEN || 'Ordinary day';
    
    // Meta line
    const metaParts = [];
    if (data.tone) metaParts.push(`Tone ${data.tone}`);
    if (data.fast?.label_en && data.fast.label_en !== 'Feast day') metaParts.push(data.fast.label_en);
    if (data.rank?.label_en && data.rank.label_en !== 'Ordinary') metaParts.push(data.rank.label_en);
    document.getElementById('daily-meta').textContent = metaParts.join(' · ');
    
    // Troparion (prefer troparion_en, then troparia_additional, then Ukrainian)
    const tropEn = data.troparion_en;
    const tropAdd = data.troparia_additional;
    const tropUk = data.troparion;
    if (tropEn && tropEn.text) {
      const tropText = tropEn.text.replace(/\s*\/\s*/g, '\n');
      document.getElementById('daily-troparion').innerText = tropText;
      const toneLabel = tropEn.tone ? ` — Tone ${tropEn.tone}` : '';
      const tropLabel = document.querySelector('#section-troparion .daily-section-label');
      if (tropLabel) tropLabel.textContent = `Troparion${toneLabel}`;
      document.getElementById('section-troparion').style.display = '';
    } else if (tropAdd && tropAdd.length > 0) {
      const t = tropAdd[0];
      const tropText = t.text.replace(/\s*\/\s*/g, '\n');
      document.getElementById('daily-troparion').innerText = tropText;
      const toneLabel = t.tone ? ` — Tone ${t.tone}` : '';
      const tropLabel = document.querySelector('#section-troparion .daily-section-label');
      if (tropLabel) tropLabel.textContent = `Troparion${toneLabel}`;
      document.getElementById('section-troparion').style.display = '';
    } else if (tropUk) {
      document.getElementById('daily-troparion').textContent = tropUk;
      document.getElementById('section-troparion').style.display = '';
    }
    
    // Kontakion (prefer kontakion_en, then kontakia_additional, then Ukrainian)
    const kondEn = data.kontakion_en;
    const kondAdd = data.kontakia_additional;
    const kondUk = data.kontakion;
    if (kondEn && kondEn.text) {
      const kondText = kondEn.text.replace(/\s*\/\s*/g, '\n');
      document.getElementById('daily-kontakion').innerText = kondText;
      const toneLabel2 = kondEn.tone ? ` — Tone ${kondEn.tone}` : '';
      const kondLabel = document.querySelector('#section-kontakion .daily-section-label');
      if (kondLabel) kondLabel.textContent = `Kontakion${toneLabel2}`;
      document.getElementById('section-kontakion').style.display = '';
    } else if (kondAdd && kondAdd.length > 0) {
      const k = kondAdd[0];
      const kondText = k.text.replace(/\s*\/\s*/g, '\n');
      document.getElementById('daily-kontakion').innerText = kondText;
      const toneLabel2 = k.tone ? ` — Tone ${k.tone}` : '';
      const kondLabel = document.querySelector('#section-kontakion .daily-section-label');
      if (kondLabel) kondLabel.textContent = `Kontakion${toneLabel2}`;
      document.getElementById('section-kontakion').style.display = '';
    } else if (kondUk) {
      document.getElementById('daily-kontakion').textContent = kondUk;
      document.getElementById('section-kontakion').style.display = '';
    }
    
    // Info grid
    document.getElementById('info-tone').textContent = data.tone ? `Tone ${data.tone}` : '—';
    document.getElementById('info-fast').textContent = data.fast?.label_en || '—';
    document.getElementById('info-rank').textContent = data.rank?.label_en || '—';
    // Season from fast
    const season = data.fast?.label_en || '';
    if (season.includes('Lent')) {
      document.getElementById('info-season').textContent = 'Great Lent';
    } else if (season.includes('Paschal')) {
      document.getElementById('info-season').textContent = 'Paschal Season';
    } else if (season.includes('Pentecost')) {
      document.getElementById('info-season').textContent = season;
    } else if (season.includes('Cheesefare')) {
      document.getElementById('info-season').textContent = 'Cheesefare Week';
    } else if (season.includes('Fast-free')) {
      document.getElementById('info-season').textContent = 'Fast-free week';
    } else {
      document.getElementById('info-season').textContent = 'Ordinary Time';
    }
    
    // Saints Ukrainian (section hidden on English site, skip rendering)
    
    // Rubrics
    if (data.rubrics) {
      document.getElementById('daily-rubrics').textContent = data.rubrics;
      document.getElementById('section-rubrics').style.display = '';
    }
    
    // Scripture readings — show references immediately, then fetch full text
    if (data.readings) {
      const r = data.readings;
      let html = '';
      if (r.epistle) {
        html += `<div class="reading-block">`;
        html += `<div class="reading-type">Epistle</div>`;
        html += `<div class="reading-ref">${r.epistle.display}</div>`;
        html += `<div class="reading-text" id="reading-epistle-text"><span class="reading-loading">Loading text…</span></div>`;
        html += `</div>`;
      }
      if (r.gospel) {
        html += `<div class="reading-block">`;
        html += `<div class="reading-type">Gospel</div>`;
        html += `<div class="reading-ref">${r.gospel.display}</div>`;
        html += `<div class="reading-text" id="reading-gospel-text"><span class="reading-loading">Loading text…</span></div>`;
        html += `</div>`;
      }
      if (html) {
        document.getElementById('daily-readings').innerHTML = html;
        document.getElementById('section-readings').style.display = '';
        // Fetch full scripture text
        loadReadingTexts(r);
      }
    }

    // Services section hidden until PWA is presentation-ready

    // Load Fathers reflections
    loadFathers(data);

    } catch(err) { console.error('Render error:', err); }
  }
  
  // ── Scripture text fetching ──
  const BIBLE_API = 'https://bible-api.com';
  
  function formatBibleRef(display) {
    // "Acts 11:19-26, 29-30; Hebrews 13:7-16" → split on ";" for separate books
    return display.split(';').map(s => s.trim());
  }
  
  function bibleApiUrl(ref) {
    // "Acts 11:19-26, 29-30" → "Acts+11:19-26,29-30"
    return BIBLE_API + '/' + ref.replace(/,\s*/g, ',').replace(/\s+/g, '+') + '?translation=web';
  }
  
  async function fetchReading(ref) {
    try {
      const resp = await fetch(bibleApiUrl(ref));
      if (!resp.ok) return null;
      const data = await resp.json();
      return data;
    } catch(e) { return null; }
  }
  
  function formatVerses(data) {
    if (!data || !data.verses) return '';
    // Group verses, add verse numbers as superscript
    return data.verses.map(v => 
      `<sup class="verse-num">${v.verse}</sup>${v.text.trim()}`
    ).join(' ');
  }
  
  async function loadReadingTexts(readings) {
    // Load epistle
    if (readings.epistle) {
      const refs = formatBibleRef(readings.epistle.display);
      const el = document.getElementById('reading-epistle-text');
      if (el) {
        let allHtml = '';
        for (const ref of refs) {
          const data = await fetchReading(ref);
          if (data) {
            if (refs.length > 1) allHtml += `<div class="reading-sub-ref">${data.reference}</div>`;
            allHtml += `<div class="reading-passage">${formatVerses(data)}</div>`;
          }
        }
        el.innerHTML = allHtml || '<span class="reading-loading">Text unavailable</span>';
      }
    }
    // Load gospel
    if (readings.gospel) {
      const refs = formatBibleRef(readings.gospel.display);
      const el = document.getElementById('reading-gospel-text');
      if (el) {
        let allHtml = '';
        for (const ref of refs) {
          const data = await fetchReading(ref);
          if (data) {
            if (refs.length > 1) allHtml += `<div class="reading-sub-ref">${data.reference}</div>`;
            allHtml += `<div class="reading-passage">${formatVerses(data)}</div>`;
          }
        }
        el.innerHTML = allHtml || '<span class="reading-loading">Text unavailable</span>';
        // Show attribution
        const attr = document.getElementById('readings-attribution');
        if (attr) attr.style.display = '';
      }
    }
  }
  
  // ── Fathers carousel ──
  let fathersData = null;
  let fathersIndex = 0;
  
  // Resolve site base path for fetching static assets
  const SITE_BASE = (function() {
    // Detect from canonical link or current path
    const path = window.location.pathname;
    const match = path.match(/^\/([^/]+)\//); // e.g. /byzantine-doors/
    return match ? '/' + match[1] : '';
  })();
  
  async function loadFathersIndex() {
    if (fathersData) return fathersData;
    try {
      const resp = await fetch(`${SITE_BASE}/api/fathers/index.json`);
      if (resp.ok) fathersData = await resp.json();
    } catch(e) { console.log('Fathers data not available'); }
    return fathersData;
  }
  
  // Normalize scripture references for matching
  // API gives "John 8, 42-51" or "John 9, 39-10, 9"
  // Fathers keys use "John 8:42-51" or "John 9:39-10:9"
  function normalizeRef(ref) {
    if (!ref) return '';
    // "John 8, 42-51" → "John 8:42-51"
    // "John 9, 39-10, 9" → "John 9:39-10:9"
    return ref.replace(/(\d+),\s*/g, '$1:').replace(/:\s+/g, ':');
  }
  
  async function loadFathers(dayData) {
    const section = document.getElementById('section-fathers');
    section.style.display = 'none';
    
    const idx = await loadFathersIndex();
    if (!idx || !idx.readings) return;
    
    // Match gospel reading to fathers entries
    const gospelDisplay = dayData.readings?.gospel?.display || '';
    if (!gospelDisplay) return;
    const normGospel = normalizeRef(gospelDisplay);
    
    // Try exact match first, then overlap match
    let entries = idx.readings[normGospel] || null;
    
    if (!entries) {
      // Fuzzy: match on book + starting chapter:verse
      const normBook = normGospel.split(/\s+/)[0];
      const normStart = normGospel.match(/(\d+:\d+)/)?.[1];
      for (const [ref, data] of Object.entries(idx.readings)) {
        const refBook = ref.split(/\s+/)[0];
        const refStart = ref.match(/(\d+:\d+)/)?.[1];
        if (normBook === refBook && normStart && refStart && normStart === refStart) {
          entries = data;
          break;
        }
      }
    }
    if (!entries || entries.length === 0) return;
    
    fathersIndex = 0;
    renderFathersCarousel(entries);
    // Show which gospel reading the reflections are for
    const refEl = document.getElementById('fathers-reading-ref');
    if (refEl) {
      const gospelRef = normGospel.split(';')[0].trim(); // first gospel if compound
      refEl.textContent = `Reflections on today's Gospel: ${gospelRef}`;
    }
    section.style.display = '';
  }
  
  function renderFathersCarousel(entries) {
    const container = document.getElementById('fathers-cards');
    const dotsContainer = document.getElementById('fathers-dots');
    
    // Build cards
    container.innerHTML = entries.map((e, i) => `
      <div class="fathers-card${i === 0 ? ' active' : ''}" data-index="${i}">
        <div class="fathers-card-header">
          <div class="fathers-name">${e.father}</div>
          <div class="fathers-work">${e.work}</div>
        </div>
        <blockquote class="fathers-quote">“${e.text}”</blockquote>
      </div>
    `).join('');
    
    // Build dots
    dotsContainer.innerHTML = entries.map((_, i) => 
      `<button class="fathers-dot${i === 0 ? ' active' : ''}" data-index="${i}" aria-label="Reflection ${i+1}"></button>`
    ).join('');
    
    // Dot click handlers
    dotsContainer.querySelectorAll('.fathers-dot').forEach(dot => {
      dot.addEventListener('click', () => {
        fathersIndex = parseInt(dot.dataset.index);
        showFather(entries);
      });
    });
    
    // Arrow handlers
    document.getElementById('fathers-prev').onclick = () => {
      fathersIndex = (fathersIndex - 1 + entries.length) % entries.length;
      showFather(entries);
    };
    document.getElementById('fathers-next').onclick = () => {
      fathersIndex = (fathersIndex + 1) % entries.length;
      showFather(entries);
    };
  }
  
  function showFather(entries) {
    document.querySelectorAll('.fathers-card').forEach(c => c.classList.remove('active'));
    document.querySelectorAll('.fathers-dot').forEach(d => d.classList.remove('active'));
    const card = document.querySelector(`.fathers-card[data-index="${fathersIndex}"]`);
    const dot = document.querySelector(`.fathers-dot[data-index="${fathersIndex}"]`);
    if (card) card.classList.add('active');
    if (dot) dot.classList.add('active');
  }

  // Touch/swipe support for fathers carousel
  (function() {
    const container = document.getElementById('fathers-cards');
    let startX = 0;
    container.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, {passive: true});
    container.addEventListener('touchend', e => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        const cards = document.querySelectorAll('.fathers-card');
        if (diff > 0) { fathersIndex = (fathersIndex + 1) % cards.length; }
        else { fathersIndex = (fathersIndex - 1 + cards.length) % cards.length; }
        showFather(Array.from(cards));
      }
    }, {passive: true});
  })();

  // Navigation
  function shiftDay(offset) {
    currentDate = new Date(currentDate.getTime() + offset * 86400000);
    loadDay(currentDate);
  }
  
  document.getElementById('prev-day').addEventListener('click', () => shiftDay(-1));
  document.getElementById('next-day').addEventListener('click', () => shiftDay(1));
  document.getElementById('today-btn').addEventListener('click', () => {
    currentDate = new Date();
    loadDay(currentDate);
  });
  
  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') shiftDay(-1);
    if (e.key === 'ArrowRight') shiftDay(1);
  });
  
  // Initial load
  loadFathersIndex(); // pre-fetch
  loadDay(currentDate);
</script>

<style>
  .daily-page-hero {
    text-align: center;
    padding: 56px 0 32px;
    position: relative;
  }
  .daily-page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 40%, rgba(186,143,67,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .daily-page-date {
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--censer-smoke);
    margin-bottom: 8px;
    position: relative;
  }
  .daily-page-feast {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 300;
    color: var(--beeswax);
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    position: relative;
    line-height: 1.3;
  }
  .daily-page-tone {
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--deep-muted);
    position: relative;
  }

  /* Date nav */
  .date-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
  }
  .date-nav-btn {
    background: none;
    border: 0.5px solid var(--gold-15);
    border-radius: 8px;
    color: var(--halo-gold);
    font-size: 24px;
    width: 44px;
    height: 44px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    font-family: var(--font-body);
  }
  .date-nav-btn:hover { background: var(--gold-06); }
  .date-nav-today {
    background: var(--gold-06);
    border: 0.5px solid var(--gold-15);
    border-radius: 6px;
    color: var(--halo-gold);
    font-family: var(--font-ui);
    font-size: 11px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 8px 20px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .date-nav-today:hover { background: var(--gold-10); }

  /* Sections */
  .daily-section {
    background: var(--warm-dark);
    border-radius: 12px;
