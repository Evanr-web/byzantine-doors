---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Glossary" description="Every unfamiliar word in Eastern Christianity, explained in plain language.">

  <section class="hero" style="padding-bottom:32px;">
    <div class="hero-content">
      <div class="section-label" style="margin-bottom:16px;">Glossary</div>
      <h1 class="hero-title" style="font-size:34px;">Words You'll Encounter</h1>
      <p class="hero-subtitle">
        Eastern Christianity has its own vocabulary. Here's every word explained in plain language.
      </p>
    </div>
  </section>

  <div class="container--narrow" style="padding-bottom:80px;">

    <div class="glossary-search">
      <input type="text" placeholder="Search terms..." id="glossary-input" />
    </div>

    <div id="glossary-list">
      <div class="glossary-letter">A</div>

      <div class="glossary-entry" data-term="akathist">
        <div class="glossary-term">Akathist</div>
        <div class="glossary-pron">/ah-KAH-thist/</div>
        <div class="glossary-def">A hymn of praise sung while standing (the word literally means "not sitting"). Usually dedicated to Christ, the Theotokos, or a saint. One of the most beloved forms of Eastern prayer.</div>
      </div>

      <div class="glossary-entry" data-term="ancestral sin">
        <div class="glossary-term">Ancestral Sin</div>
        <div class="glossary-pron">/an-SES-tral sin/</div>
        <div class="glossary-def">The Eastern understanding of the Fall. Rather than inheriting Adam's guilt (the Western "original sin" concept), humanity inherits the consequences: mortality, weakness, and a tendency toward sin.</div>
      </div>

      <div class="glossary-entry" data-term="antidoron">
        <div class="glossary-term">Antidoron</div>
        <div class="glossary-pron">/an-TID-oh-ron/</div>
        <div class="glossary-def">Blessed bread distributed after Liturgy to all present — not the Eucharist, but a sign of fellowship. The word means "instead of the gift." Anyone may receive it.</div>
      </div>

      <div class="glossary-entry" data-term="antimension">
        <div class="glossary-term">Antimension</div>
        <div class="glossary-pron">/an-tee-MEN-see-on/</div>
        <div class="glossary-def">A cloth containing relics of saints, placed on the altar and signed by the bishop. The Divine Liturgy cannot be served without it — it is the bishop's authorization made tangible.</div>
      </div>

      <div class="glossary-entry" data-term="axios">
        <div class="glossary-term">Axios</div>
        <div class="glossary-pron">/AHK-see-os/</div>
        <div class="glossary-def">"He is worthy!" — exclaimed by the congregation at an ordination, affirming the community's acceptance of the newly ordained deacon, priest, or bishop.</div>
      </div>

      <div class="glossary-letter">C</div>

      <div class="glossary-entry" data-term="chrismation">
        <div class="glossary-term">Chrismation</div>
        <div class="glossary-pron">/kriz-MAY-shun/</div>
        <div class="glossary-def">Anointing with holy chrism oil, the Eastern equivalent of Confirmation. Received immediately after Baptism — even for infants. Seals the gift of the Holy Spirit.</div>
      </div>

      <div class="glossary-letter">D</div>

      <div class="glossary-entry" data-term="deacon">
        <div class="glossary-term">Deacon</div>
        <div class="glossary-pron">/DEE-kun/</div>
        <div class="glossary-def">An ordained minister who assists at Liturgy — proclaiming the Gospel, leading the litanies, censing the church. The word means "servant."</div>
      </div>

      <div class="glossary-entry" data-term="divine liturgy">
        <div class="glossary-term">Divine Liturgy</div>
        <div class="glossary-pron">/dih-VINE LIT-er-jee/</div>
        <div class="glossary-def">The central worship service of the Eastern Church. Almost entirely sung, rich in ritual, and understood as a genuine participation in the worship of heaven.</div>
      </div>

      <div class="glossary-entry" data-term="dormition">
        <div class="glossary-term">Dormition</div>
        <div class="glossary-pron">/dor-MIH-shun/</div>
        <div class="glossary-def">The "falling asleep" of the Theotokos (the Mother of God). Not "death" but a peaceful passing into eternal life. A major feast celebrated August 15.</div>
      </div>

      <div class="glossary-letter">E</div>

      <div class="glossary-entry" data-term="ectenia">
        <div class="glossary-term">Ectenia</div>
        <div class="glossary-pron">/ek-teh-NEE-ah/</div>
        <div class="glossary-def">A litany of petitions led by the deacon, to which the congregation responds "Lord, have mercy" or "Grant this, O Lord." The structural backbone of the Liturgy's prayers.</div>
      </div>

      <div class="glossary-entry" data-term="epiklesis">
        <div class="glossary-term">Epiklesis</div>
        <div class="glossary-pron">/eh-PIK-leh-sis/</div>
        <div class="glossary-def">The prayer invoking the Holy Spirit to transform bread and wine into the Body and Blood of Christ. The East emphasizes this moment; the West historically emphasized the "words of institution."</div>
      </div>

      <div class="glossary-entry" data-term="epitaphios">
        <div class="glossary-term">Epitaphios</div>
        <div class="glossary-pron">/eh-pih-TAH-fee-os/</div>
        <div class="glossary-def">An embroidered cloth depicting Christ's burial, placed on a bier and venerated on Holy Friday. Carried in procession around the church in one of the most solemn moments of the liturgical year.</div>
      </div>

      <div class="glossary-letter">G</div>

      <div class="glossary-entry" data-term="great fast">
        <div class="glossary-term">Great Fast</div>
        <div class="glossary-pron">/grayt fast/</div>
        <div class="glossary-def">The 40-day Lenten period before Pascha (Easter). The strictest fasting season in the Eastern calendar — no meat, dairy, fish, wine, or oil on most days.</div>
      </div>

      <div class="glossary-letter">H</div>

      <div class="glossary-entry" data-term="hesychasm">
        <div class="glossary-term">Hesychasm</div>
        <div class="glossary-pron">/HEZ-ih-kazm/</div>
        <div class="glossary-def">A contemplative prayer tradition emphasizing inner stillness (hesychia) and the repetition of the Jesus Prayer. Associated with Mount Athos and St. Gregory Palamas.</div>
      </div>

      <div class="glossary-entry" data-term="holy unction">
        <div class="glossary-term">Holy Unction</div>
        <div class="glossary-pron">/HOH-lee UNK-shun/</div>
        <div class="glossary-def">The sacrament of anointing the sick with blessed oil, accompanied by prayers for healing of body and soul. Served by multiple priests when possible.</div>
      </div>

      <div class="glossary-entry" data-term="horologion">
        <div class="glossary-term">Horologion</div>
        <div class="glossary-pron">/hor-oh-LOH-gee-on/</div>
        <div class="glossary-def">The "Book of Hours" — the liturgical book containing the fixed prayers for each hour of the day. The backbone of the Eastern prayer cycle.</div>
      </div>

      <div class="glossary-letter">I</div>

      <div class="glossary-entry" data-term="iconostasis">
        <div class="glossary-term">Iconostasis</div>
        <div class="glossary-pron">/eye-koh-NAH-stah-sis/</div>
        <div class="glossary-def">The wall of icons between the nave and the sanctuary. It has three doors: the Royal Doors in the center, and two smaller doors on the sides. Every icon has a specific place and meaning.</div>
      </div>

      <div class="glossary-letter">K</div>

      <div class="glossary-entry" data-term="kontakion">
        <div class="glossary-term">Kontakion</div>
        <div class="glossary-pron">/kon-TAH-kee-on/</div>
        <div class="glossary-def">A short hymn summarizing the theological meaning of a feast day, paired with the troparion. Together they form the musical "thesis and response" of each celebration.</div>
      </div>

      <div class="glossary-letter">L</div>

      <div class="glossary-entry" data-term="litiya">
        <div class="glossary-term">Litiya</div>
        <div class="glossary-pron">/lih-TEE-yah/</div>
        <div class="glossary-def">A special blessing of bread, wheat, wine, and oil performed at Vespers on the eve of major feasts. The blessed bread is distributed to the faithful afterward.</div>
      </div>

      <div class="glossary-letter">M</div>

      <div class="glossary-entry" data-term="menaion">
        <div class="glossary-term">Menaion</div>
        <div class="glossary-pron">/meh-NAY-on/</div>
        <div class="glossary-def">A liturgical book organized by month, containing the hymns, readings, and prayers for each saint's commemoration and feast day. There are twelve volumes — one for each month.</div>
      </div>

      <div class="glossary-letter">O</div>

      <div class="glossary-entry" data-term="octoechos">
        <div class="glossary-term">Octoechos</div>
        <div class="glossary-pron">/ok-TOH-eh-hos/</div>
        <div class="glossary-def">The system of eight musical tones that cycle weekly through the liturgical year. Each tone has its own melodies and hymn texts, giving each week a distinct musical character.</div>
      </div>

      <div class="glossary-letter">P</div>

      <div class="glossary-entry" data-term="pantocrator">
        <div class="glossary-term">Pantocrator</div>
        <div class="glossary-pron">/pan-TOH-krah-tor/</div>
        <div class="glossary-def">"Ruler of All" — the title and iconic depiction of Christ, usually painted in the central dome of a church. He gazes down with an expression that is both fierce and tender, holding a Gospel book.</div>
      </div>

      <div class="glossary-entry" data-term="pascha">
        <div class="glossary-term">Pascha</div>
        <div class="glossary-pron">/PAH-skah/</div>
        <div class="glossary-def">Easter — the Feast of Feasts, the Resurrection of Christ. The most important celebration in the Eastern calendar. "Christ is risen!" is the greeting for forty days.</div>
      </div>

      <div class="glossary-entry" data-term="prokeimenon">
        <div class="glossary-term">Prokeimenon</div>
        <div class="glossary-pron">/pro-KAY-meh-non/</div>
        <div class="glossary-def">A psalm verse chanted before Scripture readings in the Liturgy, setting the tone for the passage that follows. The word means "that which is set before."</div>
      </div>

      <div class="glossary-letter">R</div>

      <div class="glossary-entry" data-term="royal doors">
        <div class="glossary-term">Royal Doors</div>
        <div class="glossary-pron">/ROY-al dorz/</div>
        <div class="glossary-def">The central doors of the iconostasis, through which only clergy may pass. They open at key moments in the Liturgy — when Christ, the King of Glory, comes to the people.</div>
      </div>

      <div class="glossary-letter">T</div>

      <div class="glossary-entry" data-term="theosis">
        <div class="glossary-term">Theosis</div>
        <div class="glossary-pron">/thee-OH-sis/</div>
        <div class="glossary-def">Divinization — the process of becoming united with God by grace. The ultimate purpose of human existence in Eastern theology. "God became human so that humans might become God" (St. Athanasius).</div>
      </div>

      <div class="glossary-entry" data-term="theotokos">
        <div class="glossary-term">Theotokos</div>
        <div class="glossary-pron">/thee-oh-TOH-kos/</div>
        <div class="glossary-def">Literally "God-bearer" — the title given to Mary at the Council of Ephesus (431 AD). It's a statement about Jesus — that the one she bore was truly God.</div>
      </div>

      <div class="glossary-entry" data-term="trisagion">
        <div class="glossary-term">Trisagion</div>
        <div class="glossary-pron">/tri-SAH-gee-on/</div>
        <div class="glossary-def">"Holy God, Holy Mighty, Holy Immortal, have mercy on us." One of the most ancient hymns in Christianity, sung at every Divine Liturgy and in daily prayers.</div>
      </div>

      <div class="glossary-entry" data-term="troparion">
        <div class="glossary-term">Troparion</div>
        <div class="glossary-pron">/troh-PAR-ee-on/</div>
        <div class="glossary-def">A short hymn that captures the theme of a feast day, saint, or liturgical occasion. Think of it as the "thesis statement" of the day in musical form.</div>
      </div>
    </div>

  </div>

</BaseLayout>

<script>
  const input = document.getElementById('glossary-input');
  input?.addEventListener('input', () => {
    const q = (input as HTMLInputElement).value.toLowerCase();
    const entries = document.querySelectorAll('.glossary-entry');
    const letters = document.querySelectorAll('.glossary-letter');

    entries.forEach(entry => {
      const el = entry as HTMLElement;
      const text = el.textContent?.toLowerCase() || '';
      el.style.display = (q === '' || text.includes(q)) ? 'block' : 'none';
    });

    letters.forEach(letter => {
      const el = letter as HTMLElement;
      let next = el.nextElementSibling;
      let hasVisible = false;
      while (next && !next.classList.contains('glossary-letter')) {
        if (next.classList.contains('glossary-entry') && (next as HTMLElement).style.display !== 'none') {
          hasVisible = true;
        }
        next = next.nextElementSibling;
      }
      el.style.display = hasVisible ? 'block' : 'none';
    });
  });
</script>

<style>
  .glossary-search { margin-bottom: 32px; }
  .glossary-search input {
    width: 100%;
    max-width: 400px;
    padding: 12px 20px;
    background: var(--icon-wall);
    border: 0.5px solid var(--gold-10);
    border-radius: 8px;
    color: var(--beeswax);
    font-family: var(--font-body);
    font-size: 16px;
    outline: none;
    transition: border-color 0.2s;
  }
  .glossary-search input::placeholder { color: var(--deep-muted); }
  .glossary-search input:focus { border-color: var(--gold-40); }
  .glossary-letter {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 300;
    color: var(--halo-gold);
    opacity: 0.5;
    margin: 32px 0 16px;
  }
  .glossary-entry {
    padding: 16px 0;
    border-bottom: 0.5px solid var(--gold-06);
  }
  .glossary-term {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    color: var(--beeswax);
    margin-bottom: 4px;
  }
  .glossary-pron {
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--deep-muted);
    margin-bottom: 6px;
  }
  .glossary-def {
    font-size: 15px;
    color: var(--aged-vellum);
    line-height: 1.6;
  }
</style>
