    margin-bottom: 20px;
  }
  .ff-body h2 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    color: var(--beeswax);
    margin: 48px 0 16px;
    letter-spacing: 0.5px;
  }
