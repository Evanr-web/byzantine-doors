    opacity: 0.7;
    line-height: 0.8;
    margin: 8px 14px 0 0;
    font-weight: 400;
  }
  .ff-body em {
    color: var(--censer-smoke);
  }
  .ff-body ul {
    padding-left: 20px;
  }
  .ff-body li {
    font-size: 15px;
    margin-bottom: 8px;
  }

  /* Article images */
  .article-image {
    margin: 36px 0;
    text-align: center;
  }
  .article-image img {
    max-width: 100%;
    max-height: 500px;
    border: 0.5px solid var(--gold-10);
    border-radius: 8px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.3);
  }
  .article-image figcaption {
    font-family: var(--font-ui);
    font-size: 12px;
    color: var(--deep-muted);
