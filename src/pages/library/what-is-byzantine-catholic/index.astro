<LibraryArticleLayout
  title="What Is a Byzantine Catholic?"
  subtitle="Eastern tradition, Western communion — the Christians who hold both lungs together."
  category="Identity"
  heroImage="/byzantine-doors/images/hagia-sophia-imperial-gate.jpg"
