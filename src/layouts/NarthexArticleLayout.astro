---
import BaseLayout from './BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  title: string;
  subtitle?: string;
  heroImage?: string;
  heroImageAlt?: string;
  readTime?: string;
}

const {
  title,
  subtitle,
  heroImage,
  heroImageAlt = '',
  readTime = '8 min read',
} = Astro.props;
---

<BaseLayout title={title} description={subtitle}>

  {heroImage && (
    <section class="lib-hero">
      <div class="lib-hero-image-wrap">
        <img src={heroImage} alt={heroImageAlt} class="lib-hero-image" loading="eager" />
        <div class="lib-hero-overlay"></div>
      </div>
      <div class="lib-hero-content">
        <div class="section-label" style="margin-bottom:12px;">The Narthex</div>
        <h1 class="lib-hero-title">{title}</h1>
        {subtitle && <p class="lib-hero-subtitle">{subtitle}</p>}
      </div>
    </section>
  )}

  <div class="article-surface">
    <div class="container--narrow">
      <nav class="breadcrumbs">
        <a href={`${base}/`}>Home</a>
        <span class="sep">›</span>
        <a href={`${base}/narthex/`}>Narthex</a>
        <span class="sep">›</span>
        <span style="color: var(--beeswax);">{title}</span>
      </nav>

      <div class="lib-meta-bar">
        <div class="lib-meta-item">
          <span class="lib-meta-label">Section</span>
          <span class="lib-meta-value">The Narthex</span>
        </div>
        <div class="lib-meta-item">
          <span class="lib-meta-label">Read time</span>
          <span class="lib-meta-value">{readTime}</span>
        </div>
      </div>

      <article class="lib-article-body">
        <slot />
      </article>

      <nav class="lib-back-nav">
        <a href={`${base}/narthex/`} class="lib-back-link">
          <span class="lib-back-arrow">←</span>
          <span>Back to the Narthex</span>
        </a>
      </nav>

    </div>
  </div>

</BaseLayout>

<style>
  .lib-hero {
    position: relative;
    min-height: 45vh;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
  }
  .lib-hero-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .lib-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .lib-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13,11,8,0.3) 0%,
      rgba(13,11,8,0.5) 40%,
      rgba(13,11,8,0.85) 80%,
      rgba(13,11,8,1) 100%
    );
  }
  .lib-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 720px;
    padding: 0 40px 48px;
  }
  .lib-hero-title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 300;
    color: var(--beeswax);
    letter-spacing: 2px;
    line-height: 1.3;
    margin-bottom: 12px;
  }
  .lib-hero-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--censer-smoke);
    line-height: 1.6;
  }

  .lib-meta-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    padding: 20px 0;
    margin-bottom: 32px;
    border-bottom: 0.5px solid var(--gold-10);
  }
  .lib-meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .lib-meta-label {
    font-family: var(--font-ui);
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--deep-muted);
  }
  .lib-meta-value {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--aged-vellum);
  }

  .lib-article-body {
    padding-bottom: 40px;
  }
  .lib-article-body :global(p) {
    margin-bottom: 20px;
    font-size: 17px;
    line-height: 1.85;
    color: var(--aged-vellum);
  }
  .lib-article-body :global(h2) {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    color: var(--beeswax);
    margin: 48px 0 16px;
    letter-spacing: 0.5px;
  }
  .lib-article-body :global(h3) {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 400;
    color: var(--beeswax);
    margin: 36px 0 12px;
  }
  .lib-article-body :global(.drop-cap)::first-letter {
    font-family: var(--font-display);
    font-size: 56px;
    float: left;
    color: var(--halo-gold);
    opacity: 0.7;
    line-height: 0.8;
    margin: 8px 14px 0 0;
    font-weight: 400;
  }
  .lib-article-body :global(em) {
    color: var(--censer-smoke);
  }
  .lib-article-body :global(.article-image) {
    margin: 36px 0;
    text-align: center;
  }
  .lib-article-body :global(.article-image img) {
    max-width: 100%;
    max-height: 500px;
    border: 0.5px solid var(--gold-10);
    border-radius: 8px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.3);
  }
  .lib-article-body :global(.article-image figcaption) {
    font-family: var(--font-ui);
    font-size: 12px;
    color: var(--deep-muted);
    margin-top: 10px;
    font-style: italic;
  }
  .lib-article-body :global(.article-image--wide) {
    margin-left: -80px;
    margin-right: -80px;
  }
  .lib-article-body :global(.article-image--wide img) {
    max-height: 600px;
    width: 100%;
    object-fit: cover;
  }

  .lib-back-nav {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 0 80px;
    border-top: 0.5px solid var(--gold-10);
  }
  .lib-back-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--censer-smoke);
    text-decoration: none;
    transition: color 0.2s;
  }
  .lib-back-link:hover {
    color: var(--halo-gold);
    opacity: 1;
  }
  .lib-back-arrow {
    font-size: 16px;
  }

  @media (max-width: 768px) {
    .lib-hero { min-height: 35vh; }
    .lib-hero-title { font-size: 28px; }
    .lib-hero-content { padding: 0 20px 36px; }
    .lib-meta-bar { flex-direction: column; gap: 12px; }
    .lib-back-nav { flex-direction: column; }
    .lib-article-body :global(.article-image--wide) {
      margin-left: -20px;
      margin-right: -20px;
    }
  }
</style>
